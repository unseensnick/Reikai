#!/usr/bin/env bash
# Reikai CHANGELOG enforcement (see .claude/rules/workflow.md: "After completing any code change"
# and "Public-facing naming"). Lints a staged CHANGELOG.md so the changelog stays scannable and
# name-safe:
#   1. no content-source names in any newly added line;
#   2. every new [Unreleased] entry under Additions / Changes / Fixes leads with a self-contained
#      bold headline ending in . ! or ? (Other is exempt), and stays under a length cap.
# Tracked here as the source of truth; activate on a clone with:
#   cp .githooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit
set -u

git diff --cached --name-only | grep -qx 'CHANGELOG.md' || exit 0

deny='e-hentai|ehentai|exhentai|nhentai|pururin|8muses|hentaifox|asmhentai|koharu|schalenetwork'
fail=0

# 1) No content-source names in any newly added CHANGELOG line.
bad_names=$(git diff --cached -U0 -- CHANGELOG.md | grep -E '^\+[^+]' | grep -inE "$deny" || true)
if [ -n "$bad_names" ]; then
  echo "CHANGELOG: a new line names a content source, genericize it (see Public-facing naming):"
  echo "$bad_names"
  fail=1
fi

# 2) Structure of the staged [Unreleased] section. Only [Unreleased] is checked, so already-released
#    sections are never re-flagged.
issues=$(git show :CHANGELOG.md | awk '
  /^## \[Unreleased\]/ { u=1; next }
  /^## \[/             { u=0 }
  !u                  { next }
  /^### /             { sec=$0; sub(/^### /,"",sec); next }
  /^\*\*/             { next }                       # bold sub-header line
  /^- / {
    if (length($0) > 320)
      print "  - over the length cap (>320 chars); trim to a bold headline + one sentence:\n    " $0
    if (sec != "Other" && $0 !~ /^- \*\*[^*]+[.!?]\*\*/)
      print "  - needs a self-contained bold headline ending in . ! or ? (Other is exempt):\n    " $0
  }
')
if [ -n "$issues" ]; then
  echo "CHANGELOG [Unreleased] entry issues:"
  echo "$issues"
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo
  echo "Fix CHANGELOG.md, or use 'git commit --no-verify' if this is intentional."
  exit 1
fi
exit 0
