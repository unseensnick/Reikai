<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 8 follow-up CR8 (revised): the Manga / Light novel sources tab row lives in the
  activity's app bar (via TabbedInterface + activityBinding.mainTabs) so it follows the
  collapse-on-scroll behavior the rest of the chrome uses. The controller's view tree just
  hosts the swap container — the existing source_recycler for manga and a hidden ComposeView
  for the LN sources list.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/browse_layout">

    <FrameLayout
        android:id="@+id/browse_frame_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/background">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/source_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            tools:listitem="@layout/source_header_item" />

        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/ln_sources_compose"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Adding bottom sheet after main content -->
    <include layout="@layout/extensions_bottom_sheet"
        android:id="@+id/bottom_sheet"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
