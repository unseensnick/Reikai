<?xml version="1.0" encoding="utf-8"?>
<!--
  Wrapper layout for the Extensions tab page in ExtensionBottomSheet (Phase 8 follow-up CR6).
  Hosts inner sub-tabs (Manga / Light novels) above a FrameLayout that swaps between the
  existing recycler_with_scroller view (Manga sub-tab — bit-identical to pre-change behavior)
  and a ComposeView (Light novels sub-tab) mounting LnPluginBrowseContent.

  The included recycler_with_scroller layout keeps its existing root id (recycler_layout) so
  the ExtensionBottomSheet.extensionFrameLayout getter (findViewWithTag("TabbedRecycler0"))
  still resolves the inner RecyclerWithScrollerView via tag-recursion.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/inner_tabs"
        style="@style/Theme.Widget.Tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabGravity="fill"
        app:tabIndicatorColor="?attr/colorSecondary"
        app:tabMaxWidth="0dp"
        app:tabMode="fixed"
        app:tabTextColor="@color/tabs_selector_background" />

    <FrameLayout
        android:id="@+id/inner_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/manga_recycler_root"
            layout="@layout/recycler_with_scroller" />

        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/ln_compose"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
