<?xml version="1.0" encoding="utf-8"?>
<!--
    Single-container host for the tabbed Edit Categories screen. The Manga / Novels tab strip
    lives in the activity's `mainTabs` (same pattern as Browse and Recents) so the nested
    `liftAppbarWith` calls from the hosted CategoryController / NovelCategoryController push
    content below the combined toolbar + tab row without double-padding.
-->
<com.bluelinelabs.conductor.ChangeHandlerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/categories_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />
